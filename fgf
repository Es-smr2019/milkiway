import random
from aiogram import Router, F, types
from aiogram.filters import Command
from database import register_user, get_balance, record_game
from keyboards import get_zov_bet_keyboard, get_after_game_keyboard, get_back_button
from config import CURRENCY_NAME, ZOV_CHANCES

router = Router()

@router.message(Command("zov", "зов"))
@router.message(F.text == "🎲 Зов Духов (/zov)")
@router.message(F.text == "🎲 Игры (/zov)")
async def cmd_zov_entry(message: types.Message):
    """
    Вход в игру «Зов Духов».
    Если указана ставка (/zov 100), запускаем игру сразу.
    Если без аргументов (/zov или кнопка в меню) — показываем клавиатуру выбора ставки.
    """
    user = message.from_user
    await register_user(user.id, user.username, user.full_name)
    balance = await get_balance(user.id)
    
    args = message.text.split()
    # Если команда вызвана с аргументом ставки (например, /zov 100 или /zov all)
    if len(args) > 1 and args[0].lower().startswith(("/zov", "/зов")):
        bet_str = args[1].lower()
        if bet_str in ["all", "все", "всё", "вабанк", "ва-банк"]:
            bet = balance
        else:
            try:
                bet = int(bet_str)
            except ValueError:
                await message.answer("❌ Ставка должна быть целым числом или `all` (`все`).", parse_mode="Markdown")
                return
        
        await process_zov_game(message, user, bet, is_callback=False)
        return

    # Если без аргументов — показываем красивое меню с кнопками ставок
    text = (
        f"🌲 **ИГРА «ЗОВ ДУХОВ»** 🔮\n\n"
        f"Вы взываете к древним духам тайги. Ваша ставка может как раствориться, так и преумножиться до **10x**!\n\n"
        f"📊 **Возможные отклики духов:**\n"
        f"• 💀 **Ничего:** 0x — шанс 55% (ставка проигрывается)\n"
        f"• 📜 **Дух Амона:** 1.5x — шанс 25%\n"
        f"• 🐉 **Дух Виверны:** 2.0x — шанс 14%\n"
        f"• 🌲 **Дух Тайги:** 5.0x — шанс 5%\n"
        f"• 🦊 **Дух Лисы:** 10.0x — шанс ровно 1%!\n\n"
        f"💰 **Ваш баланс:** **{balance:,}** {CURRENCY_NAME}\n\n".replace(",", " ") +
        f"👇 **Выберите или введите вашу ставку:**\n*(Или напишите команду `/zov <ставка>` в чат)*"
    )
    await message.answer(text, reply_markup=get_zov_bet_keyboard(balance), parse_mode="Markdown")


from aiogram.types import ReplyKeyboardMarkup, KeyboardButton, InlineKeyboardMarkup, InlineKeyboardButton
from aiogram.utils.keyboard import ReplyKeyboardBuilder, InlineKeyboardBuilder
from config import PRYATKI_FOX_MULTIPLIERS

def get_main_reply_keyboard() -> ReplyKeyboardMarkup:
    """Главная клавиатура (Reply) для личных сообщений."""
    builder = ReplyKeyboardBuilder()
    builder.row(
        KeyboardButton(text="🎲 Зов Духов (/zov)"),
        KeyboardButton(text="🦊 Прятки (/pryatki)")
    )
    builder.row(
        KeyboardButton(text="💰 Баланс"),
        KeyboardButton(text="🎁 Ежедневный бонус")
    )
    builder.row(
        KeyboardButton(text="📊 Рейтинг"),
        KeyboardButton(text="👤 Профиль")
    )
    builder.row(KeyboardButton(text="❓ Помощь"))
    return builder.as_markup(resize_keyboard=True)

def get_main_inline_menu() -> InlineKeyboardMarkup:
    """Главное меню в виде Inline-кнопок."""
    builder = InlineKeyboardBuilder()
    builder.row(
        InlineKeyboardButton(text="🎲 Зов Духов (/zov)", callback_data="play_zov_prompt"),
        InlineKeyboardButton(text="🦊 Прятки (/pryatki)", callback_data="play_pryatki_prompt")
    )
    builder.row(
        InlineKeyboardButton(text="💰 Мой баланс", callback_data="show_balance"),
        InlineKeyboardButton(text="🎁 Ежедневный бонус", callback_data="claim_bonus")
    )
    builder.row(
        InlineKeyboardButton(text="📊 Топ игроков", callback_data="show_top"),
        InlineKeyboardButton(text="👤 Мой профиль", callback_data="show_profile")
    )
    builder.row(InlineKeyboardButton(text="❓ Помощь и правила", callback_data="show_help"))
    return builder.as_markup()

def get_zov_bet_keyboard(balance: int = 1000) -> InlineKeyboardMarkup:
    """Интерактивное меню выбора ставки для игры /zov."""
    builder = InlineKeyboardBuilder()
    
    bets = [50, 100, 250, 500, 1000]
    available_buttons = []
    for bet in bets:
        if balance >= bet:
            available_buttons.append(InlineKeyboardButton(text=f"{bet} 🪙", callback_data=f"zov_bet:{bet}"))
    
    for i in range(0, len(available_buttons), 3):
        builder.row(*available_buttons[i:i+3])
    
    if balance > 0:
        builder.row(InlineKeyboardButton(text=f"🔥 Ва-банк ({balance} 🪙)", callback_data="zov_bet:all"))
    else:
        builder.row(InlineKeyboardButton(text="⚠️ На балансе 0 🪙", callback_data="no_balance"))
        
    builder.row(InlineKeyboardButton(text="◀️ В главное меню", callback_data="back_to_main"))
    return builder.as_markup()

def get_after_game_keyboard(last_bet: int) -> InlineKeyboardMarkup:
    """Кнопки после завершения игры /zov."""
    builder = InlineKeyboardBuilder()
    if last_bet > 0:

def get_pryatki_board_keyboard(game_id: int, board_list: list, foxes_found: int, bet: int, status: str) -> InlineKeyboardMarkup:
    """Создает игровое поле 8x8 для Пряток с кнопкой завершения игры внизу."""
    builder = InlineKeyboardBuilder()
    
    # Кнопки 8x8 поля
    cell_buttons = []
    for i, state in enumerate(board_list):
        if state == "?":
            text = "❓"
            cb = f"pry_c:{game_id}:{i}" if status == "active" else "noop"
        elif state == "space":
            text = "🌌"
            cb = "noop"
        elif state == "fox":
            text = "🦊"
            cb = "noop"
        elif state == "sun":
            text = "☀️"
            cb = "noop"
        else:
            text = "❓"
            cb = "noop"
            
        cell_buttons.append(InlineKeyboardButton(text=text, callback_data=cb))
        
    # Размещаем по 8 кнопок в каждом из 8 рядов
    for row_idx in range(8):
        builder.row(*cell_buttons[row_idx*8 : (row_idx+1)*8])
        
    # Нижняя кнопка завершения или рестарта
    if status == "active":
        current_mult = PRYATKI_FOX_MULTIPLIERS.get(foxes_found, 1.0)
        current_win = int(bet * current_mult)
        builder.row(InlineKeyboardButton(
            text=f"🛑 Закончить игру (Забрать {current_win:,} 🪙)".replace(",", " "),
            callback_data=f"pry_cash:{game_id}"
        ))
    else:
        if bet > 0:
            builder.row(InlineKeyboardButton(text=f"🔄 Сыграть снова ({bet} 🪙)", callback_data=f"pry_bet:{bet}"))
        builder.row(
            InlineKeyboardButton(text="🦊 Другая ставка", callback_data="play_pryatki_prompt"),
            InlineKeyboardButton(text="💰 Баланс", callback_data="show_balance")
        )
        builder.row(InlineKeyboardButton(text="◀️ В меню", callback_data="back_to_main"))
        
    return builder.as_markup()


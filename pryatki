@router.callback_query(F.data.startswith("pry_bet:"))
async def cb_pryatki_bet(callback: types.CallbackQuery):
    """Обработка выбора конкретной ставки из меню или при рестарте."""
    user = callback.from_user
    await register_user(user.id, user.username, user.full_name)
    balance = await get_balance(user.id)
    
    bet_param = callback.data.split(":")[1]
    if bet_param == "all":
        bet = balance
    else:
        try:
            bet = int(bet_param)
        except ValueError:
            await callback.answer("❌ Некорректная ставка.", show_alert=True)
            return

    await process_pryatki_start(callback.message, user, bet, is_callback=True, callback_query=callback)

async def process_pryatki_start(message_obj: types.Message, user: types.User, bet: int, is_callback: bool = False, callback_query: types.CallbackQuery = None):
    """Запуск партии в Прятки: списываем ставку, создаем поле 8x8 и высылаем кнопки."""
    balance = await get_balance(user.id)
    
    if bet <= 0:
        err_msg = "❌ Ставка должна быть больше 0 монет!"
        if is_callback and callback_query:
            await callback_query.answer(err_msg, show_alert=True)
        else:
            await message_obj.answer(err_msg)
        return

    if bet > balance:
        err_msg = f"⚠️ Недостаточно монет на балансе! У вас есть только {balance:,} {CURRENCY_NAME}".replace(",", " ")
        if is_callback and callback_query:
            await callback_query.answer(err_msg, show_alert=True)
        else:
            await message_obj.answer(err_msg)
        return

    active_game = await get_active_pryatki_game(user.id)
    if active_game:
        err_msg = "📌 У вас уже есть активная игра! Сначала завершите её."
        if is_callback and callback_query:
            await callback_query.answer(err_msg, show_alert=True)
        else:
            await message_obj.answer(err_msg)
        return

    # Создаем игру в базе данных
    game_id = await create_pryatki_game(user.id, bet)
    board_list = ["?"] * 64
    
    text = (
        f"🦊 **ИГРА «ПРЯТКИ С ДУХАМИ»** 🔮\n"
        f"🪙 Ставка: **{bet:,}** {CURRENCY_NAME}\n\n".replace(",", " ") +
        f"🔎 **Поле 8 на 8:** Нажимайте на клетки `❓`!\n"
        f"• 🦊 **Лиса (0/3):** множитель **1.0x** (следующая удвоит до **2.0x**!)\n"
        f"• ☀️ **Солнце:** опасность **22%**\n\n"
        f"👇 *Открывайте клетки или нажмите «🛑 Закончить игру (Забрать {bet:,} 🪙)» внизу поля.*".replace(",", " ")
    )
    
    reply_markup = get_pryatki_board_keyboard(game_id, board_list, 0, bet, "active")
    
    if is_callback and callback_query:
        try:
            await callback_query.message.edit_text(text, reply_markup=reply_markup, parse_mode="Markdown")
        except Exception:
            await callback_query.message.answer(text, reply_markup=reply_markup, parse_mode="Markdown")
        await callback_query.answer()
    else:
        await message_obj.answer(text, reply_markup=reply_markup, parse_mode="Markdown")


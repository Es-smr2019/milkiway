@router.callback_query(F.data.startswith("pry_c:"))
async def cb_pryatki_cell(callback: types.CallbackQuery):
    """Обработка нажатия на неизвестную клетку на поле 8x8."""
    user = callback.from_user
    parts = callback.data.split(":")
    game_id = int(parts[1])
    cell_idx = int(parts[2])
    
    game = await get_pryatki_game(game_id)
    if not game or game["status"] != "active":
        await callback.answer("Эта игра уже завершена!", show_alert=True)
        return
        
    if game["user_id"] != user.id:
        await callback.answer("❌ Это не ваша игра! Откройте свою через команду /pryatki", show_alert=True)
        return
        
    board_list = json.loads(game["board"])
    if board_list[cell_idx] != "?":
        await callback.answer("Эта клетка уже открыта!", show_alert=True)
        return
        
    foxes_found = game["foxes_found"]
    bet = game["bet"]
    
    # Определяем шанс в зависимости от уже найденного количества лис
    chances = PRYATKI_CHANCES.get(foxes_found, {"space": 38.0, "sun": 50.0, "fox": 12.0})
    weights = [chances["space"], chances["sun"], chances["fox"]]
    outcome = random.choices(["space", "sun", "fox"], weights=weights, k=1)[0]
    
    board_list[cell_idx] = outcome
    
    if outcome == "space":
        # 🌌 Космос: безопасно, продолжаем
        await update_pryatki_game_state(game_id, user.id, board_list, foxes_found, "active")
        current_mult = PRYATKI_FOX_MULTIPLIERS.get(foxes_found, 1.0)
        current_win = int(bet * current_mult)
        
        text = (
            f"🦊 **ИГРА «ПРЯТКИ С ДУХАМИ»** 🔮\n"
            f"🪙 Ставка: **{bet:,}** {CURRENCY_NAME}\n\n".replace(",", " ") +
            f"🌌 **Выпал КОСМОС!** Вы в безопасности.\n"
            f"Текущая выплата: **{current_win:,}** {CURRENCY_NAME} (множитель **{current_mult}x**)\n"
            f"🦊 Найденных лис: **{foxes_found}/3**\n\n"
            f"👇 Ищите дальше или заберите выигрыш кнопкой внизу:"
        ).replace(",", " ")
        
        await callback.message.edit_text(text, reply_markup=get_pryatki_board_keyboard(game_id, board_list, foxes_found, bet, "active"), parse_mode="Markdown")
        await callback.answer("🌌 Космос! Безопасно.")
        
    elif outcome == "fox":
        # 🦊 Лиса: удваиваем выигрыш!
        new_foxes = foxes_found + 1
        if new_foxes >= 3:
            # Нашли все 3 лисы! Победа с максимальным множителем 8x
            win_amount = int(bet * PRYATKI_FOX_MULTIPLIERS[3])
            await update_pryatki_game_state(game_id, user.id, board_list, new_foxes, "won", win_amount)
            new_balance = await get_balance(user.id)
            
            text = (
                f"🎉 **НЕВЕРОЯТНАЯ ПОБЕДА!** 🦊🦊🦊\n"
                f"Вы нашли всех трёх Духов Лисы на поле!\n\n"
                f"📈 Итоговый множитель: **8.0x**\n"
                f"🪙 Ставка: **{bet:,}** {CURRENCY_NAME}\n".replace(",", " ") +
                f"🏆 Выигрыш: **+{win_amount:,}** {CURRENCY_NAME}!\n".replace(",", " ") +
                f"💰 Новый баланс: **{new_balance:,}** {CURRENCY_NAME}".replace(",", " ")
            )
            await callback.message.edit_text(text, reply_markup=get_pryatki_board_keyboard(game_id, board_list, new_foxes, bet, "won"), parse_mode="Markdown")
            await callback.answer("🎉 Вы нашли 3-ю Лису! Джекпот 8x!", show_alert=True)
        else:
            await update_pryatki_game_state(game_id, user.id, board_list, new_foxes, "active")
            current_mult = PRYATKI_FOX_MULTIPLIERS[new_foxes]
            current_win = int(bet * current_mult)
            sun_chance = PRYATKI_CHANCES.get(new_foxes, {"sun": 50.0})["sun"]
            
            text = (
                f"🦊 **ДУХ ЛИСЫ НАЙДЕН! ({new_foxes}/3)** ✨\n"
                f"📈 Ваша выплата удваивается: **{current_mult}x**\n"
                f"💰 Потенциальный выигрыш: **{current_win:,}** {CURRENCY_NAME}\n\n".replace(",", " ") +
                f"⚠️ **Внимание:** риск наткнуться на ловушку Солнца возрос до **{sun_chance}%**!\n\n"
                f"👇 Продолжайте открывать клетки или нажмите «🛑 Закончить игру (Забрать {current_win:,} 🪙)» внизу:".replace(",", " ")
            )
            await callback.message.edit_text(text, reply_markup=get_pryatki_board_keyboard(game_id, board_list, new_foxes, bet, "active"), parse_mode="Markdown")
            await callback.answer(f"🦊 Лиса найдена! Множитель {current_mult}x!", show_alert=True)
            
    elif outcome == "sun":
        # ☀️ Солнце: Ловушка! Игра проиграна
        await update_pryatki_game_state(game_id, user.id, board_list, foxes_found, "lost", 0)
        new_balance = await get_balance(user.id)
        
        text = (
            f"☀️ **ЛОВУШКА СОЛНЦА!** 💀\n"
            f"Вы кликнули на клетку, где пряталось ослепительное Солнце. Духи отвернулись от вас.\n\n"
            f"📉 Игра окончена. Ставка **-{bet:,}** {CURRENCY_NAME} сгорела.\n".replace(",", " ") +
            f"💰 Новый баланс: **{new_balance:,}** {CURRENCY_NAME}".replace(",", " ")
        )
        await callback.message.edit_text(text, reply_markup=get_pryatki_board_keyboard(game_id, board_list, foxes_found, bet, "lost"), parse_mode="Markdown")
        await callback.answer("☀️ Ловушка Солнца! Игра проиграна.", show_alert=True)

@router.callback_query(F.data.startswith("pry_cash:"))
async def cb_pryatki_cashout(callback: types.CallbackQuery):
    """Нажатие на кнопку «Закончить игру (Забрать выигрыш/ставку)»."""
    user = callback.from_user
    game_id = int(callback.data.split(":")[1])
    
    game = await get_pryatki_game(game_id)
    if not game or game["status"] != "active":
        await callback.answer("Эта игра уже завершена!", show_alert=True)
        return
        
    if game["user_id"] != user.id:
        await callback.answer("❌ Это не ваша игра!", show_alert=True)
        return
        
    foxes_found = game["foxes_found"]
    bet = game["bet"]
    current_mult = PRYATKI_FOX_MULTIPLIERS.get(foxes_found, 1.0)
    win_amount = int(bet * current_mult)
    board_list = json.loads(game["board"])
    
    await update_pryatki_game_state(game_id, user.id, board_list, foxes_found, "cashed_out", win_amount)
    new_balance = await get_balance(user.id)
    
    text = (
        f"🛑 **ИГРА ЗАВЕРШЕНА ДОСРОЧНО**\n\n"
        f"Вы решили вовремя остановиться и забрать текущий куш!\n"
        f"🦊 Найденных лис: **{foxes_found}/3**\n"
        f"📈 Множитель: **{current_mult}x**\n"
        f"🏆 Зачислено: **+{win_amount:,}** {CURRENCY_NAME}\n\n".replace(",", " ") +
        f"💰 Ваш баланс: **{new_balance:,}** {CURRENCY_NAME}".replace(",", " ")
    )
    
    await callback.message.edit_text(text, reply_markup=get_pryatki_board_keyboard(game_id, board_list, foxes_found, bet, "cashed_out"), parse_mode="Markdown")
    await callback.answer(f"🎉 Вы успешно забрали {win_amount:,} монет!".replace(",", " "), show_alert=True)

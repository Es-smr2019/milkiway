import random
import json
from aiogram import Router, F, types
from aiogram.filters import Command
from database import (
    register_user, get_balance, get_active_pryatki_game,
    create_pryatki_game, get_pryatki_game, update_pryatki_game_state
)
from keyboards import get_pryatki_bet_keyboard, get_pryatki_board_keyboard
from config import CURRENCY_NAME, PRYATKI_FOX_MULTIPLIERS, PRYATKI_CHANCES

router = Router()

@router.message(Command("pryatki", "прятки"))
@router.message(F.text == "🦊 Прятки (/pryatki)")
async def cmd_pryatki_entry(message: types.Message):
    """Вход в игру Прятки с духами."""
    user = message.from_user
    await register_user(user.id, user.username, user.full_name)
    
    # Проверяем наличие активной игры
    active_game = await get_active_pryatki_game(user.id)
    if active_game:
        board_list = json.loads(active_game["board"])
        bet = active_game["foxes_found"] # temporary check
        foxes = active_game["foxes_found"]
        bet_amount = active_game["bet"]
        mult = PRYATKI_FOX_MULTIPLIERS.get(foxes, 1.0)
        
        text = (
            f"📌 **У вас уже есть активная игра в «Прятки с духами»!**\n"
            f"🪙 Ставка: **{bet_amount:,}** {CURRENCY_NAME}\n"
            f"🦊 Найденных лис: **{foxes}/3** (множитель: **{mult}x**)\n\n"
            f"👇 Продолжайте открывать клетки или нажмите «🛑 Закончить игру» внизу поля:"
        ).replace(",", " ")
        await message.answer(
            text,
            reply_markup=get_pryatki_board_keyboard(active_game["game_id"], board_list, foxes, bet_amount, "active"),
            parse_mode="Markdown"
        )
        return

    balance = await get_balance(user.id)
    args = message.text.split()
    
    # Если аргумент ставки передан сразу (/pryatki 100)
    if len(args) > 1 and args[0].lower().startswith(("/pryatki", "/прятки")):
        bet_str = args[1].lower()
        if bet_str in ["all", "все", "всё", "вабанк", "ва-банк"]:
            bet = balance
        else:
            try:
                bet = int(bet_str)
            except ValueError:
                await message.answer("❌ Ставка должна быть целым числом или `all` (`все`).", parse_mode="Markdown")
                return
        
        await process_pryatki_start(message, user, bet, is_callback=False)
        return

    # Показываем меню выбора ставки
    text = (
        f"🦊 **ИГРА «ПРЯТКИ С ДУХАМИ»** 🔮\n\n"
        f"Перед вами появится скрытое поле **8 на 8** (64 клетки). Открывайте клетки, чтобы искать Духов Лисы!\n\n"
        f"📜 **Правила:**\n"
        f"• 🦊 **Лиса:** ваша текущая выплата удваивается (1x ➔ 2x ➔ 4x ➔ 8x победа! Можно выбить до 3 лис).\n"
        f"• 🌌 **Космос:** безопасно! Вы не выиграли и не проиграли, продолжаете игру.\n"
        f"• ☀️ **Солнце (Ловушка):** игра сразу оканчивается, ставка проигрывается.\n\n"
        f"🛑 **Закончить игру:** вы можете в любой момент нажать кнопку внизу поля и забрать текущий выигрыш!\n"
        f"⚠️ *Шанс выбить Солнце увеличивается с каждой найденной Лисой!*\n\n"
        f"💰 **Ваш баланс:** **{balance:,}** {CURRENCY_NAME}\n\n".replace(",", " ") +
        f"👇 **Выберите или введите вашу ставку:**"
    )
    await message.answer(text, reply_markup=get_pryatki_bet_keyboard(balance), parse_mode="Markdown")

